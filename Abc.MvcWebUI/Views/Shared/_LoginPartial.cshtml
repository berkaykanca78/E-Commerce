<ul class="navbar-nav my-2 my-lg-0">
    @if (Request.IsAuthenticated)
    {
        //Kullanıcı Adını ve Logout linklerini Çıkar
        <li class="nav-item active mx-3">
            <a class="nav-link" href="/Account">@User.Identity.Name</a>
        </li>
        <li class="nav-item active mx-3">
            <a class="btn btn-danger" href="/Account/Logout">Çıkış Yap</a>
        </li>
    }
    else
    {
        //Login ve Register Linklerini Çıkar
        <li class="nav-item active mx-3">
            <a class="nav-link" href="/Account/Login">Giriş Yap</a>
        </li>
        <li class="nav-item active mx-3">
            <a class="nav-link" href="/Account/Register">Kayıt Ol</a>
        </li>
    }
</ul>
